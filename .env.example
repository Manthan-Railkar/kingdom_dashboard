# =============================================
# QUANTUM 26 — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (local dev)
MONGODB_URI=mongodb://localhost:27017/quantum26

# MongoDB Atlas (production) — replace with your Atlas URI
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/quantum26?retryWrites=true&w=majority

# JWT
JWT_SECRET=quantum26_ultra_secret_change_this_in_production
JWT_EXPIRES_IN=24h

# Admin
ADMIN_USERNAME=superadmin
ADMIN_DISPLAY_NAME=Super Admin
ADMIN_ACCESS_KEY=2626

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
